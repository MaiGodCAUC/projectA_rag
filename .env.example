# ============================================================
# 国航内部员工智能知识助手 - 环境变量模板
# 复制此文件为 .env 并填写真实值：
#   cp .env.example .env
# ============================================================

# ---------- LLM 配置 ----------
# Provider: openai / qwen / deepseek
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=                    # 国内模型需填写，OpenAI 不需要
LLM_MODEL=gpt-4o

# ---------- Embedding 配置 ----------
# Provider: openai / bge / m3e
# 注意：bge 和 m3e 是本地模型，不需要 API Key
EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=               # 默认复用 LLM_API_KEY
EMBEDDING_MODEL=text-embedding-3-small

# ---------- Qdrant 向量数据库 ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=airchina_knowledge_base

# ---------- 服务配置 ----------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---------- LangSmith（可选） ----------
# LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=airchina-rag
