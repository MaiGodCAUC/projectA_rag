# ============================================================
# 国航内部员工智能知识助手 - 环境变量模板
# 复制此文件为 .env 并填写真实值：
#   cp .env.example .env
# ============================================================

# ---------- LLM 配置 ----------
# Provider: deepseek（DeepSeek）/ qwen（通义千问）
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=                          # 不填则自动使用默认地址
LLM_MODEL=deepseek-chat                 # deepseek-chat / qwen-plus 等

# ---------- Embedding 配置 ----------
# Provider: bge（本地）/ m3e（本地）/ qwen（API）
# bge 和 m3e 无需 API Key，首次运行会自动下载模型到本地
EMBEDDING_PROVIDER=bge
# EMBEDDING_API_KEY=                     # bge/m3e 不需要；qwen 时填写
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5  # 或 moka-ai/m3e-base
EMBEDDING_DEVICE=cpu                    # cpu / cuda

# ---------- Qdrant 向量数据库 ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=airchina_knowledge_base

# ---------- 服务配置 ----------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---------- LangSmith（可选） ----------
# LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=airchina-rag
